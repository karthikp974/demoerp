{
  "name": "@college-erp/backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node -r tsconfig-paths/register src/main.ts",
    "dev:watch": "dotenv -e ../../.env -- nodemon --watch src --ext ts --exec ts-node -r tsconfig-paths/register src/main.ts",
    "worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:docker": "tsc -p tsconfig.build.json --noCheck",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "db:clear-operational": "dotenv -e ../../.env -- ts-node prisma/clear-operational-data.ts",
    "migrate:timetable-times": "dotenv -e ../../.env -- node scripts/migrate-timetable-times.cjs"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcrypt": "^6.0.0",
    "bullmq": "5.76.6",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "ioredis": "5.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^18.2.21",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "25.6.1",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.3.0",
    "prisma": "7.8.0",
    "source-map-support": "0.5.21",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
