# WFT Institutions demo portal — single campus (WFT), single database.
# Copy to .env — do not commit .env.

DATABASE_URL="postgresql://wft_user:wft_password@localhost:5435/wft_erp?schema=public"
DATABASE_POOL_MAX="25"
DATABASE_CONNECT_TIMEOUT_MS="5000"
DATABASE_IDLE_TIMEOUT_MS="30000"
DATABASE_TIMEZONE="Asia/Kolkata"
TZ="Asia/Kolkata"
POSTGRES_DB="wft_erp"
POSTGRES_USER="wft_user"
POSTGRES_PASSWORD="wft_password"
REDIS_HOST="localhost"
REDIS_PORT="6382"

JWT_ACCESS_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
JWT_REFRESH_SECRET="replace-with-a-different-random-secret-at-least-32-characters-long"
ERP_MASTER_PASSWORD_HASH=""
ERP_OWNER_PASSWORD="WftDemo@123"

BACKEND_PORT="4000"
FRONTEND_PORT="5173"
ERP_DEMO_HTPO_BOOTSTRAP="false"
ERP_DEMO_STUDENT_BOOTSTRAP="false"
ERP_DEMO_TIMETABLE_BOOTSTRAP="false"

DEV_API_PROXY_TARGET="http://127.0.0.1:4002"
EMAIL_ENABLED="false"
EMAIL_FROM_NAME="WFT ERP"

PUBLIC_APP_URL="http://localhost:5176"
# PREVIEW_ALLOWED_HOSTS="demo.wftinst.local"

# WorkflowTech Activity Hub — forward login/page events to wftact dashboard
WFTACT_SITE="demo"
